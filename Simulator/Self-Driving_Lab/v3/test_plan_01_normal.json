{
    "experiment_name": "T1_Normal_ClosedLoop",
    "description": "정상 Closed-Loop 최적화 - 목표 흡광도 0.8, 초기 RPM 2000",
    "target": {
        "metric": "max_absorbance",
        "value": 0.8,
        "tolerance": 0.05
    },
    "initial_rpm": 2000,
    "max_iterations": 5,
    "sequence": [
        {"step": 1, "device": "plate_hotel", "port": 50052, "cmd": "EJECT:3"},
        {"step": 2, "device": "liquid_handler", "port": 50051, "cmd": "DISPENSE:50"},
        {"step": 3, "device": "centrifuge", "port": 50054, "cmd": "SPIN:2000"},
        {"step": 4, "device": "plate_reader", "port": 50053, "cmd": "SCAN:2000"}
    ]
}
